<PleasantWindow xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:vm="using:RomManager.ViewModels"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:pages="clr-namespace:RomManager.Pages"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:DataType="vm:MainWindowViewModel"
                x:Class="RomManager.MainWindow"
                Title="Rom Manager" Subtitle="Rom Manager" TitleBarType="NavigationViewClassicExtended"
                WindowStartupLocation="CenterScreen" ExtendsContentIntoTitleBar="True" Icon="/Assets/logo.ico"
                MinWidth="600" MinHeight="500" Width="1200" Height="700">
    <Panel>
        <NavigationView x:Name="MainNavigationView" AlwaysOpen="True" IsOpen="True" BindWindowSettings="True">
            <NavigationViewItem Header="Home" Margin="0,0,0,5"
                                Icon="{x:Static MaterialIcons.ViewDashboard}">
                <NavigationViewItem.Content>
                    <pages:HomePage />
                </NavigationViewItem.Content>
            </NavigationViewItem>

            <NavigationViewItem x:Name="LibraryNavigationItem" Header="Library" Margin="0,0,0,5" IsExpanded="True"
                                Icon="{x:Static MaterialIcons.Library}">
                <NavigationViewItem.Content>
                    <pages:LibraryPage />
                </NavigationViewItem.Content>
            </NavigationViewItem>


            <NavigationViewItem Header="Settings" DockPanel.Dock="Bottom"
                                Icon="{x:Static MaterialIcons.CogOutline}">
                <NavigationViewItem.Content>
                    <pages:SettingsPage />
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </NavigationView>
    </Panel>
</PleasantWindow>
