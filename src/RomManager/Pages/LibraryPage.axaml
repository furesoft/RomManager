<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:PleasantUI.Controls;assembly=PleasantUI"
             xmlns:models="clr-namespace:RomManager.Models"
             xmlns:viewModels="clr-namespace:RomManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" Margin="15"
             x:DataType="viewModels:LibraryPageViewModel"
             x:Class="RomManager.Pages.LibraryPage">
    <Grid RowDefinitions="Auto,*" RowSpacing="8">
        <controls:CommandBar DefaultLabelPosition="Bottom"
                             IsOpen="False"
                             IsSticky="True"
                             OverflowButtonVisibility="Auto">
            <controls:CommandBarButton Label="Scan"
                                       Icon="{DynamicResource CubeScan}" />
            <controls:CommandBarButton Label="Import"
                                       Icon="{DynamicResource CopyRegular}" />
            <controls:CommandBarButton Label="Find Duplicates"
                                       Icon="{DynamicResource EditRegular}" />
        </controls:CommandBar>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Games}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Game">
                    <Image Source="{Binding CoverArt}" Width="100" Height="150" Stretch="UniformToFill" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>