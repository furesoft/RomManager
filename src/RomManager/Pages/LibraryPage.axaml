<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:PleasantUI.Controls;assembly=PleasantUI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" Margin="15"
             x:Class="RomManager.Pages.LibraryPage">
    <StackPanel Spacing="5">
        <controls:CommandBar DefaultLabelPosition="Bottom"
                             IsOpen="True"
                             IsSticky="True"
                             OverflowButtonVisibility="Collapsed">
            <controls:CommandBarButton Label="Scan"
                                       Icon="{DynamicResource CubeScan}" />
            <controls:CommandBarButton Label="Import"
                                       Icon="{DynamicResource CopyRegular}" />
            <controls:CommandBarButton Label="Find Duplicates"
                                       Icon="{DynamicResource EditRegular}" />
        </controls:CommandBar>
    </StackPanel>
</UserControl>
