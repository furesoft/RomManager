<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:RomManager.Converters"
             xmlns:models="clr-namespace:RomManager.Models"
             xmlns:viewModels="clr-namespace:RomManager.ViewModels"
             xmlns:regionDetection="clr-namespace:RomManager.Core.RegionDetection"
             xmlns:controls="clr-namespace:RomManager.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" Margin="15"
             x:DataType="viewModels:LibraryPageViewModel"
             x:Class="RomManager.Pages.LibraryPage">
    <UserControl.Resources>
        <converters:SystemIconNameToImageConverter x:Key="SystemIconNameToImageConverter" />
        <converters:RegionToImageConverter x:Key="RegionToImageConverter" />
        <converters:FilterComboBoxItemToTextConverter x:Key="FilterComboBoxItemToTextConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
        <CommandBar DefaultLabelPosition="Bottom"
                             IsOpen="False"
                             IsSticky="True"
                             OverflowButtonVisibility="Auto">
            <CommandBarButton Label="Scan"
                                       Icon="{x:Static MaterialIcons.Magnify}" />
            <CommandBarButton Label="Import" Command="{Binding ImportRomCommand}"
                                       Icon="{DynamicResource CopyRegular}" />
            <CommandBarButton Label="Find Duplicates"
                                       Icon="{DynamicResource EditRegular}" />
        </CommandBar>

        <StackPanel Grid.Row="1" Spacing="15">
            <!-- System Filter -->
            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Top" Margin="5,0" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="System: " VerticalAlignment="Top" Margin="0,7,0,0" />
                <controls:FilterSelector Grid.Column="1"
                                         HorizontalAlignment="Stretch"
                                         ItemsSource="{Binding AvailableSystems}"
                                         SelectedItems="{Binding SelectedSystems, Mode=TwoWay}">
                    <controls:FilterSelector.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="{Binding Converter={StaticResource SystemIconNameToImageConverter}}"
                                       Width="16"
                                       Height="16"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Converter={StaticResource FilterComboBoxItemToTextConverter}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </controls:FilterSelector.ItemTemplate>
                </controls:FilterSelector>
            </Grid>

            <!-- Region Filter -->
            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Top" Margin="5,0" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="Region: " VerticalAlignment="Top" Margin="0,7,0,0" />
                <controls:FilterSelector Grid.Column="1"
                                         HorizontalAlignment="Stretch"
                                         ItemsSource="{Binding AvailableRegions}"
                                         SelectedItems="{Binding SelectedRegions, Mode=TwoWay}">
                    <controls:FilterSelector.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border CornerRadius="2" ClipToBounds="True" Width="20" Height="14" VerticalAlignment="Center">
                                    <Image Source="{Binding Converter={StaticResource RegionToImageConverter}}"
                                           Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="{Binding Converter={StaticResource FilterComboBoxItemToTextConverter}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </controls:FilterSelector.ItemTemplate>
                </controls:FilterSelector>
            </Grid>

            <!-- Genre Filter -->
            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Top" Margin="5,0" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="Genre: " VerticalAlignment="Top" Margin="0,7,0,0" />
                <controls:FilterSelector Grid.Column="1"
                                         HorizontalAlignment="Stretch"
                                         ItemsSource="{Binding AvailableGenres}"
                                         SelectedItems="{Binding SelectedGenres, Mode=TwoWay}">
                    <controls:FilterSelector.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource FilterComboBoxItemToTextConverter}}"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </controls:FilterSelector.ItemTemplate>
                </controls:FilterSelector>
            </Grid>

            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center" Margin="5,0" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="Favourites: " VerticalAlignment="Center" />
                <ToggleSwitch Grid.Column="1"
                              HorizontalAlignment="Left"
                              IsChecked="{Binding FavoritesOnly, Mode=TwoWay}" />
            </Grid>

            <TextBlock Text="{Binding FilteredGamesCount, Mode=OneWay, StringFormat='{}{0} Games'}" />
        </StackPanel>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsRepeater ItemsSource="{Binding PagedGames}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="120"
                                       MinColumnSpacing="12"
                                       MinRowSpacing="12"
                                       ItemsJustification="Start" />
                </ItemsRepeater.Layout>

                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:Game">
                        <Border Width="130"
                                Padding="6"
                                CornerRadius="8"
                                Background="Transparent"
                                ClipToBounds="True">

                            <Grid RowDefinitions="Auto, Auto, Auto">
                                <Grid Grid.Row="0" Width="110" Height="150" HorizontalAlignment="Center">
                                    <Border CornerRadius="6"
                                            ClipToBounds="True"
                                            Background="#202020"
                                            BoxShadow="0 4 8 0 #50000000">
                                        <Image Source="{Binding CoverArt, Mode=OneWay}"
                                               Stretch="UniformToFill" />
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Systems}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top"
                                                  Margin="4">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:SystemInfo">
                                                <Border Background="#B31A1A1A"
                                                        CornerRadius="4"
                                                        Padding="4"
                                                        BoxShadow="0 2 4 0 #30000000">
                                                    <Image Source="{Binding Converter={StaticResource SystemIconNameToImageConverter}}"
                                                           Width="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Height="18"
                                                           ToolTip.Tip="{Binding Name}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ItemsControl ItemsSource="{Binding Regions}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top"
                                                  Margin="4">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="regionDetection:Region">
                                                <Border Background="#B31A1A1A"
                                                        CornerRadius="4"
                                                        Padding="4"
                                                        BoxShadow="0 2 4 0 #30000000">
                                                    <Image Source="{Binding Converter={StaticResource RegionToImageConverter}}"
                                                           Width="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Height="18"
                                                           ToolTip.Tip="{Binding }" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <TextBlock Grid.Row="2"
                                           Text="{Binding Name}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#E0E0E0"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxLines="2"
                                           Margin="0,6,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Margin="0,4,0,0">
            <Button Content="&lt;&lt;" Command="{Binding FirstPageCommand}" IsEnabled="{Binding HasPreviousPage}" />
            <Button Content="&lt;" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}" />
            <TextBlock Text="{Binding PageInfo}"
                       VerticalAlignment="Center"
                       Margin="8,0" />
            <Button Content="&gt;" Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}" />
            <Button Content="&gt;&gt;" Command="{Binding LastPageCommand}" IsEnabled="{Binding HasNextPage}" />
        </StackPanel>
    </Grid>
</UserControl>
