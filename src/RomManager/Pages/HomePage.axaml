<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RomManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" Margin="15"
             x:Class="RomManager.Pages.HomePage"
             x:CompileBindings="True"
             x:DataType="vm:HomePageViewModel">
    <ScrollViewer>
        <StackPanel Spacing="16">
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <DashboardCard Grid.Row="0" Grid.Column="0"
                               Header="Library">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Library Content" />
                    </StackPanel>
                </DashboardCard>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
